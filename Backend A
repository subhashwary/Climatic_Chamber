import serial
import time

# --- Configuration ---
# Change 'COM12' to match your actual port (e.g., '/dev/ttyUSB0' on Linux/Mac)
SERIAL_PORT = 'COM7' 
BAUD_RATE = 115200

try:
    # Initialize serial connection
    ser = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=1)
    # Flush the buffer to clear any old data
    ser.flush()
    
    print(f"Connected to {SERIAL_PORT}. Press Ctrl+C to stop.")
    time.sleep(2) # Wait for connection to stabilize

    while True:
        if ser.in_waiting > 0:
            # Read a line of data and decode it from bytes to string
            line = ser.readline().decode('utf-8').rstrip()
            
            if line:
                print(f"{line}")

except serial.SerialException as e:
    print(f"Error: Could not open port {SERIAL_PORT}. {e}")
except KeyboardInterrupt:
    print("\nStopping script...")
finally:
    if 'ser' in locals() and ser.is_open:
        ser.close()
        print("Serial port closed.")
