<!DOCTYPE html>
<html>
<head>
    <title>Sensor Dashboard</title>

    <style>
        body {
            font-family: Arial;
            margin: 20px;
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header img {
            height: 60px;
        }

        .title-container {
            flex-grow: 1;
            text-align: center;
        }

        .title {
            font-size: 22px;
            font-weight: bold;
        }

        .subtitle {
            font-size: 16px;
            margin-top: 4px;
        }

        .container {
            margin-top: 20px;
        }

        /* SENSOR SECTION */
        .sensor-container {
            display: flex;
            border: 1px solid #ccc;
            justify-content: space-between;
            gap: 0px;
        }

        .sensor-box {
            width: 48%;
            padding: 20px;
            text-align: center;
        }

        .sensor-box:first-child {
            border-right: 2px solid #000;
        }

        .btn-row {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 8px;
        }

        .sensor-title {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        /* BUTTONS INSIDE EACH PANEL */
        .panel-buttons {
            margin-top: 20px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 6px;
        }

        /* TOP CONTROL BUTTONS */
        .top-buttons {
            margin-top: 20px;
            text-align: center;
        }

        button {
            width: 45px;
            height: 35px;
            font-size: 10px;
            padding: 2px;
            cursor: pointer;
        }

        .start-btn {
            background-color: green;
            color: white;
            border: none;
        }

        .stop-btn {
            background-color: red;
            color: white;
            border: none;
        }

        .footer {
            text-align: center;
            margin-top: 80px;
            padding: 10px;
            font-size: 20px;
            border-top: 1px solid #ccc;
            color: #555;
        }

    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        <img src="images/cense-logo.png">

        <div class="title-container">
            <div class="title">Indian Institute of Science, Bangalore</div>
            <div class="subtitle">Centre for Nano Science</div>
        </div>

        <img src="images/iisc-logo.jpg">
    </div>

    <hr>

    <!-- MAIN CONTENT -->
    <div class="container">

        <h1>GTRE RAKE</h1>

        <!-- SENSOR DISPLAY -->
        <div class="sensor-container">

            <!-- LEFT PANEL -->
            <div class="sensor-box">
                <div class="sensor-title">Pressure Sensor</div>
                <p id="pressure">--</p>

                <div class="panel-buttons">
                    <div class="btn-row"><span>Sensor 1</span><button>Btn 1</button><button>Btn 6</button></div>
                    <div class="btn-row"><span>Sensor 2</span><button>Btn 2</button><button>Btn 7</button></div>
                    <div class="btn-row"><span>Sensor 3</span><button>Btn 3</button><button>Btn 8</button></div>
                    <div class="btn-row"><span>Sensor 4</span><button>Btn 4</button><button>Btn 9</button></div>
                    <div class="btn-row"><span>Sensor 5</span><button>Btn 5</button><button>Btn 10</button></div>
                </div>
            </div>

            <!-- RIGHT PANEL -->
            <div class="sensor-box">
                <div class="sensor-title">Temperature Sensor</div>
                <p id="temperature">--</p>

                <div class="panel-buttons">
                    <div class="btn-row"><span>Sensor 1</span><button>Btn 1</button><button>Btn 6</button></div>
                    <div class="btn-row"><span>Sensor 2</span><button>Btn 2</button><button>Btn 7</button></div>
                    <div class="btn-row"><span>Sensor 3</span><button>Btn 3</button><button>Btn 8</button></div>
                    <div class="btn-row"><span>Sensor 4</span><button>Btn 4</button><button>Btn 9</button></div>
                    <div class="btn-row"><span>Sensor 5</span><button>Btn 5</button><button>Btn 10</button></div>
                </div>
            </div>
        </div>
            </div>

        </div>

        <!-- CONTROL BUTTONS -->
        <div class="top-buttons">
            <button onclick="startDevice()" class="start-btn">START</button>
            <button onclick="stopDevice()" class="stop-btn">STOP</button>
            <button onclick="resetDevice()">RESET</button>
        </div>

    </div>

    <script>
        async function fetchData() {
            const res = await fetch("http://127.0.0.1:5000/data");
            const data = await res.json();

            document.getElementById("pressure").innerText = data.pressure;
            document.getElementById("temperature").innerText = data.temperature;
        }

        async function resetDevice() {
            await fetch("http://127.0.0.1:5000/reset", { method: "POST" });
            alert("Reset command sent");
        }

        async function startDevice() {
            await fetch("http://127.0.0.1:5000/start", { method: "POST" });
            alert("Start command sent");
        }

        async function stopDevice() {
            await fetch("http://127.0.0.1:5000/stop", { method: "POST" });
            alert("Stop command sent");
        }

        setInterval(fetchData, 2000);
    </script>

    <footer class="footer">
        Packaging and Systems Engineering Facility - 2026
    </footer>

</body>
</html>
