<!DOCTYPE html>
<html>
<head>
    <title>Sensor Dashboard</title>

    <style>
        body {
    font-family: Arial;
    margin: 20px;
    background-color: #f4f7fb; /* light technical grey-blue */
}

        .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #0b3d91; /* IISc-style deep blue */
    padding: 10px;
    border-radius: 6px;
}

.title, .subtitle {
    color: white;
}

        .header img {
            height: 60px;
        }

        .title-container {
            flex-grow: 1;
            text-align: center;
        }

        .title {
            font-size: 44px;
            font-weight: bold;
        }

       .subtitle {
            font-size: 32px;   /* same size as title */
            font-weight: bold; /* make it bold */
            margin-top: 4px;
        }

        .container {
            margin-top: 20px;
        }

        /* SENSOR SECTION */
        .sensor-container {
    display: flex;
    border: none; /* remove old border */
    gap: 20px;
    margin-top: 25px;
}

        .sensor-box {
    width: 48%;
    padding: 20px;
    text-align: center;
    background-color: #ffffff;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

        .sensor-box:first-child {
            border-right: 2px solid #000;
        }

        .sensor-title {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        /* BUTTONS INSIDE EACH PANEL */
        .panel-buttons {
    margin-top: 20px;
    display: grid;
    grid-template-columns: 110px 80px 80px; /* Sensor | Volt | Psi */
    row-gap: 10px;
    align-items: center;
        }

        .output-header {
    grid-column: 2 / 4; /* spans Volt + Psi columns */
    text-align: center;
    font-weight: bold;
    font-size: 14px;
}

        .btn-header {
    font-weight: bold;
    text-align: center;
}

.sensor-label {
    text-align: left;
}

        /* TOP CONTROL BUTTONS */
        .top-buttons {
            margin-top: 20px;
            text-align: center;
        }

        button {
    width: 50px;
    height: 35px;
    font-size: 11px;
    border-radius: 4px;
    border: 1px solid #ccc;
}

.start-btn {
    background-color: #28a745;
}

.stop-btn {
    background-color: #dc3545;
}

        .footer {
            text-align: center;
            margin-top: 80px;
            padding: 10px;
            font-size: 20px;
            border-top: 1px solid #ccc;
            color: #555;
        }

        .main-title {
    text-align: center;
    font-size: 24px;
    font-weight: bold;
    margin-top: 10px;
}

.sub-main {
    text-align: center;
    font-size: 25px;
    margin-top: 4px;
    color: #444;
    font-weight: 500;
}

        h1 {
    text-align: center;
}

    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        <img src="images/cense-logo.png">

        <div class="title-container">
            <div class="title">Indian Institute of Science, Bangalore</div>
            <div class="subtitle">Centre for Nano Science and Engineering</div>
        </div>

        <img src="images/iisc-logo.jpg">
    </div>

    <hr>

    <!-- MAIN CONTENT -->
    <div class="container">

        <div class="main-title">GTRE RAKE Sensor Assembly</div>
        <div class="sub-main">Realtime Monitoring</div>
        

        <!-- SENSOR DISPLAY -->
        <div class="sensor-container">

            <!-- LEFT PANEL -->
            <div class="sensor-box">
                <div class="sensor-title">Pressure Sensor</div>
                <p id="pressure">--</p>

                <div class="panel-buttons">
    <!-- OUTPUT ROW -->
    <div></div>
    <div class="output-header">Output</div>

    <!-- COLUMN HEADERS -->
    <div></div>
    <div class="btn-header">Volt</div>
    <div class="btn-header">Psi</div>

    <!-- SENSOR ROWS -->
    <div class="sensor-label">Sensor 1</div><button>Btn 1</button><button>Btn 6</button>
    <div class="sensor-label">Sensor 2</div><button>Btn 2</button><button>Btn 7</button>
    <div class="sensor-label">Sensor 3</div><button>Btn 3</button><button>Btn 8</button>
    <div class="sensor-label">Sensor 4</div><button>Btn 4</button><button>Btn 9</button>
    <div class="sensor-label">Sensor 5</div><button>Btn 5</button><button>Btn 10</button>
</div>
            </div>

            <!-- RIGHT PANEL -->
            <div class="sensor-box">
                <div class="sensor-title">Temperature Sensor</div>
                <p id="temperature">--</p>

                <div class="panel-buttons">
    <!-- OUTPUT ROW -->
    <div></div>
    <div class="output-header">Output</div>

    <!-- COLUMN HEADERS -->
    <div></div>
    <div class="btn-header">Volt</div>
    <div class="btn-header">°C</div>

    <!-- SENSOR ROWS -->
    <div class="sensor-label">Sensor 1</div><button>Btn 1</button><button>Btn 6</button>
    <div class="sensor-label">Sensor 2</div><button>Btn 2</button><button>Btn 7</button>
    <div class="sensor-label">Sensor 3</div><button>Btn 3</button><button>Btn 8</button>
    <div class="sensor-label">Sensor 4</div><button>Btn 4</button><button>Btn 9</button>
    <div class="sensor-label">Sensor 5</div><button>Btn 5</button><button>Btn 10</button>
</div>
            </div>
        </div>
            </div>

        </div>

        <!-- CONTROL BUTTONS -->
        <div class="top-buttons">
            <button onclick="startDevice()" class="start-btn">START</button>
            <button onclick="stopDevice()" class="stop-btn">STOP</button>
            <button onclick="resetDevice()">RESET</button>
        </div>

    </div>

    <script>
        async function fetchData() {
            const res = await fetch("http://127.0.0.1:5000/data");
            const data = await res.json();

            document.getElementById("pressure").innerText = data.pressure;
            document.getElementById("temperature").innerText = data.temperature;
        }

        async function resetDevice() {
            await fetch("http://127.0.0.1:5000/reset", { method: "POST" });
            alert("Reset command sent");
        }

        async function startDevice() {
            await fetch("http://127.0.0.1:5000/start", { method: "POST" });
            alert("Start command sent");
        }

        async function stopDevice() {
            await fetch("http://127.0.0.1:5000/stop", { method: "POST" });
            alert("Stop command sent");
        }

        setInterval(fetchData, 2000);
    </script>

    <footer class="footer">
        Packaging and Systems Facility (PASF) - 2026
    </footer>

</body>
</html>
