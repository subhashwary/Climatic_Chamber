<!DOCTYPE html>
<html>
<head>
    <title>Sensor Dashboard</title>

    <style>
    body {
    font-family: Arial;
    margin: 20px;
    background-color: #f4f7fb; /* light technical grey-blue */
}

.header {
    display: flex;
    align-items: center;
    justify-content: space-between;

    background-color: #d9e6f2;  /* light academic blue */
    padding: 10px;
    border-radius: 6px;
}

.title, .subtitle {
    color: #1f2d3a;   /* dark text for contrast */
}

.header img {
            height: 60px;
        }

.title-container {
            flex-grow: 1;
            text-align: center;
        }

.title {
            font-size: 44px;
            font-weight: bold;
        }

.subtitle {
            font-size: 32px;   /* same size as title */
            font-weight: bold; /* make it bold */
            margin-top: 4px;
        }

.container {
            margin-top: 20px;
        }

        /* SENSOR SECTION */
.sensor-container {
    display: flex;
    justify-content: center;
    gap: 40px;              /* space between panels */
    margin-top: 25px;
    align-items: flex-start;
}

.sensor-box {
    width: 40%;   /* control panel size */
    
    padding: 12px 14px;
    text-align: center;
    background-color: #ffffff;

    border: 2px solid #2c3e50;
    border-radius: 4px;
    box-shadow: none;
    
}

.sensor-title {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        /* BUTTONS INSIDE EACH PANEL */
.panel-buttons {
    margin-top: 10px;
    display: grid;
    grid-template-columns: 90px 120px 120px;
    column-gap: 10px;
    row-gap: 10px;
    align-items: center;
    justify-content: center;
    width: 100%;
}

.panel-buttons button {
    width: 110px;
    height: 32px;
    font-size: 11px;
    margin: 0;
}

.output-header {
    grid-column: 2 / 4; /* spans Volt + Psi columns */
    text-align: center;
    font-weight: bold;
    font-size: 14px;
}

.btn-header {
    font-weight: bold;
    text-align: center;
}

.sensor-label {
    text-align: left;
    font-weight: bold;   /* makes Sensor 1–5 bold */
}

        /* TOP CONTROL BUTTONS */
.top-buttons {
            margin-top: 20px;
            text-align: center;
        }

        button {
    width: 50px;
    height: 35px;
    font-size: 11px;
    border-radius: 4px;
    border: 1px solid #ccc;
}

.top-buttons button {
    width: 90px;      /* bigger width */
    height: 45px;     /* taller button */
    font-size: 14px;  /* bigger text */
    margin: 5px;
    border-radius: 6px;
    cursor: pointer;
}

.start-btn {
    background-color: #28a745;
}

.stop-btn {
    background-color: #dc3545;
}

.footer {
    text-align: center;
    margin-top: 40px;
    padding: 14px;
    font-size: 18px;
    font-weight: 500;

    color: #1f2d3a;
    background: #dfe9f3;

    letter-spacing: 0.5px;
}

.main-title {
    text-align: center;
    font-size: 30px;
    font-weight: bold;
    margin-top: 45px;   /* increased from 10px */
}

.sub-main {
    text-align: center;
    font-size: 25px;
    margin-top: 4px;
    color: #444;
    font-weight: 500;
}

        h1 {
    text-align: center;
}

.sensor-title {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 12px; /* increased gap */
}

#pressure, #temperature {
    margin-bottom: 18px; /* space below sensor reading */
    font-size: 18px;
}

.btn-box {
    width: 100%;
    height: 36px;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 12px;
    font-weight: 600;

    background-color: #f4f7fb;

    border: 2px solid #2c3e50;   /* strong rectangle border */
    border-radius: 3px;          /* slight rounding */

    color: #1f2d3a;

    box-sizing: border-box;
}

    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        <img src="images/cense-logo.png">

        <div class="title-container">
            <div class="title">Centre for Nano Science and Engineering</div>
            <div class="subtitle">Indian Institute of Science, Bangalore</div>
        </div>

        <img src="images/iisc-logo.jpg">
    </div>

    <!-- MAIN CONTENT -->
    <div class="container">

        <div class="main-title">GTRE RAKE Sensor Assembly</div>
        <div class="sub-main">Realtime Monitoring</div>
        

        <!-- SENSOR DISPLAY -->
        <div class="sensor-container">

            <!-- LEFT PANEL -->
            <div class="sensor-box">
                <div class="sensor-title">Pressure Sensor</div>
                <p id="pressure"></p>

                <div class="panel-buttons">
    <!-- OUTPUT ROW -->
    <div></div>
<div class="btn-header">Output Voltage</div>
<div class="btn-header">Pressure</div>

    <!-- COLUMN HEADERS -->
    <div></div>
    <div class="btn-header">(Volt)</div>
    <div class="btn-header">(Psi)</div>

    <!-- SENSOR ROWS -->
    <div class="sensor-label">Sensor 1</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 2</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 3</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 4</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 5</div><div class="btn-box"></div><div class="btn-box"></div>
</div>
            </div>

            <!-- RIGHT PANEL -->
            <div class="sensor-box">
                <div class="sensor-title">Temperature Sensor</div>
                <p id="temperature"></p>

                <div class="panel-buttons">

    <!-- HEADER ROW -->
    <div></div>
    <div class="btn-header">Output Voltage</div>
    <div class="btn-header">Temperature</div>

    <!-- COLUMN HEADERS -->
    <div></div>
    <div class="btn-header">(Volt)</div>
    <div class="btn-header">(°C)</div>

    <!-- SENSOR ROWS -->
    <div class="sensor-label">Sensor 1</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 2</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 3</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 4</div><div class="btn-box"></div><div class="btn-box"></div>
    <div class="sensor-label">Sensor 5</div><div class="btn-box"></div><div class="btn-box"></div>

</div>
            </div>
        </div>
            </div>

        </div>

        <!-- CONTROL BUTTONS -->
        <div class="top-buttons">
            <button onclick="startDevice()" class="start-btn">START</button>
            <button onclick="stopDevice()" class="stop-btn">STOP</button>
            <button onclick="resetDevice()">RESET</button>
        </div>

    </div>

    <script>
        async function fetchData() {
            const res = await fetch("http://127.0.0.1:5000/data");
            const data = await res.json();

            document.getElementById("pressure").innerText = data.pressure;
            document.getElementById("temperature").innerText = data.temperature;
        }

        async function resetDevice() {
            await fetch("http://127.0.0.1:5000/reset", { method: "POST" });
            alert("Reset command sent");
        }

        async function startDevice() {
            await fetch("http://127.0.0.1:5000/start", { method: "POST" });
            alert("Start command sent");
        }

        async function stopDevice() {
            await fetch("http://127.0.0.1:5000/stop", { method: "POST" });
            alert("Stop command sent");
        }

        setInterval(fetchData, 2000);
    </script>

    <footer class="footer">
        Packaging and Systems Facility (PASF) - 2026
    </footer>

</body>
</html>
